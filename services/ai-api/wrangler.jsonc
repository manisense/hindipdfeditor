{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hindipdfeditor-ai-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "vars": {
    "GEMINI_MODEL": "gemini-3.5-flash",
    "ALLOWED_ORIGINS": "https://hindipdfeditor.com,https://www.hindipdfeditor.com",
    "TURNSTILE_HOSTNAMES": "hindipdfeditor.com,www.hindipdfeditor.com",
    "AI_TRANSLATION_ENABLED": "true",
    "AI_OCR_ENABLED": "true",
  },
  "secrets": {
    "required": [
      "GEMINI_API_KEY",
      "SESSION_SIGNING_SECRET",
      "TURNSTILE_SECRET_KEY",
    ],
  },
  "d1_databases": [
    {
      "binding": "AI_DB",
      "database_name": "hindipdfeditor-ai",
      "database_id": "ff58c3b6-b2be-4fe5-ade7-a9e25a0ee9b7",
      "migrations_dir": "migrations",
    },
  ],
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "41001",
      "simple": {
        "limit": 10,
        "period": 60,
      },
    },
  ],
  "routes": [
    {
      "pattern": "api.hindipdfeditor.com",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "triggers": {
    "crons": ["17 2 * * *"],
  },
}
