{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hindipdfeditor-ai-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "vars": {
    "GEMINI_MODEL": "gemini-3.5-flash",
    "ALLOWED_ORIGINS": "https://hindipdfeditor.com,https://www.hindipdfeditor.com",
    "TURNSTILE_HOSTNAMES": "hindipdfeditor.com,www.hindipdfeditor.com",
    "AI_TRANSLATION_ENABLED": "true",
    "AI_OCR_ENABLED": "true",
  },
  "secrets": {
    "required": [
      "GEMINI_API_KEY",
      "SESSION_SIGNING_SECRET",
      "TURNSTILE_SECRET_KEY",
    ],
  },
  "d1_databases": [
    {
      "binding": "AI_DB",
      "database_name": "hindipdfeditor-ai",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations",
    },
  ],
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "41001",
      "simple": {
        "limit": 10,
        "period": 60,
      },
    },
  ],
  "analytics_engine_datasets": [
    {
      "binding": "AI_ANALYTICS",
      "dataset": "hindipdfeditor_ai_api",
    },
  ],
  "observability": {
    "enabled": true,
  },
  "triggers": {
    "crons": ["17 2 * * *"],
  },
}
