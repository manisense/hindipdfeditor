# macOS
.DS_Store

# Root-local editor/tooling noise
*.log
*.tmp

# Mobile app local/generated state
mobile-app/node_modules/
mobile-app/.expo/
mobile-app/.screenshots/
mobile-app/android/
mobile-app/ios/
mobile-app/dist/
mobile-app/web-build/
mobile-app/expo-env.d.ts
mobile-app/google-play-service-account.json
mobile-app/*.tsbuildinfo

# Native signing/secrets
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
.env*.local

# Web editor local/generated state
web-app/editor/node_modules/
web-app/editor/tsconfig.tsbuildinfo
web-app/edit/

# Local Expo Module native build outputs
mobile-app/modules/*/android/.gradle/
mobile-app/modules/*/android/build/
mobile-app/modules/*/android/.cxx/
mobile-app/modules/*/ios/build/

# Redundant zip of already-tracked play-store assets
mobile-app/play-store-assets/play-store-assets.zip

